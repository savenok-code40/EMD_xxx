        <mxCell id="Y8qQ0ax3hkKe-9IbpHJT-3" value="&lt;div&gt;&lt;b&gt;kBus -&amp;gt; fsm&lt;/b&gt;&lt;br&gt;&lt;/div&gt;fsm - это объединение &lt;b&gt;union &lt;/b&gt;в структуре KBus&lt;div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; union {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; KBusAutoConfStateMachine autoconf;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; KBusConfStateMachine conf;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; KBusCommStateMachine comm;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; FwUpgradeStateMachine fwupgrade;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; } fsm;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
