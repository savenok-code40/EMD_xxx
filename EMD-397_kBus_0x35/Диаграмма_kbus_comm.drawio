        <mxCell id="Y8qQ0ax3hkKe-9IbpHJT-12" value="&lt;div&gt;typedef struct tagsyscomopen_struct&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;RTS_IEC_INT sPort;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&#x9;&lt;/span&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;/* VAR_INPUT, Enum: SYS_COM_PORTS */&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;RTS_IEC_RESULT *pResult;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; /* VAR_INPUT */&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;/* &amp;lt;param name=&quot;pResult&quot; type=&quot;OUT&quot;&amp;gt;Pointer to runtime system error code (see CmpErrors.library)&amp;lt;/param&amp;gt; */&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;RTS_IEC_HANDLE SysComOpen;&amp;nbsp; &amp;nbsp; /* VAR_OUTPUT */&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;} &lt;b&gt;syscomopen_struct&lt;/b&gt;;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="-1070" y="800" width="530" height="130" as="geometry" />
        </mxCell>
        <mxCell id="gHBDbl-WhV7u39UwyFvt-1" value="&lt;div&gt;&lt;font style=&quot;color: rgb(102, 178, 255);&quot;&gt;&lt;font color=&quot;#66b2ff&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;ModbusState&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;typedef enum {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; MB_STATE_WRITE,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; MB_STATE_READ,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; MB_STATE_PENDING,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; MB_STATE_READY&lt;/div&gt;&lt;div&gt;} &lt;b&gt;ModbusState&lt;/b&gt;;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="-2220" y="-1600" width="260" height="140" as="geometry" />
        </mxCell>
        <mxCell id="gHBDbl-WhV7u39UwyFvt-2" value="&lt;div&gt;&lt;font style=&quot;color: rgb(102, 178, 255);&quot;&gt;&lt;font color=&quot;#66b2ff&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;KBus&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;typedef struct KBus {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;cnt&lt;/b&gt;; ///&amp;lt; Число подключённых модулей&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;scanIdx&lt;/b&gt;; ///&amp;lt; Итератор модулей расширения&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;modIdx&lt;/b&gt;; // индекс модуля&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp; ModbusStateMachine &lt;b&gt;mb&lt;/b&gt;;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; union {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; KBusAutoConfStateMachine autoconf;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; KBusConfStateMachine conf;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; KBusCommStateMachine comm;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; FwUpgradeStateMachine fwupgrade;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; } &lt;b&gt;fsm&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; int &lt;b&gt;smb_fd&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; RTS_HANDLE &lt;b&gt;reset_gpio&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;cnt_drv_mod&lt;/b&gt;;&amp;nbsp; ///&amp;lt; Кол-djо модулей в конфигурации алгоритма&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; RTS_HANDLE &lt;b&gt;mtx&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;available&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;n_counters&lt;/b&gt;; ///&amp;lt; Макс. число счётчиков на модуль&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;n_analogs&lt;/b&gt;; ///&amp;lt; Макс. число аналоговых каналов на модуль&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; ///При размере буфера в 256 байт невозможен опрос более 31 модуля&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;buf&lt;/b&gt;[MODBUS_MAX_LENGTH];&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint16_t &lt;b&gt;bufLen&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; KBusModule &lt;b&gt;modules&lt;/b&gt;[KBUS_MODULES_MAX];&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; IoConfigConnector &lt;b&gt;scanConnector&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; IoConfigParameter &lt;b&gt;scanParameters&lt;/b&gt;[4];&lt;/div&gt;&lt;div&gt;} KBus;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="-3470" y="-1600" width="430" height="510" as="geometry" />
        </mxCell>
        <mxCell id="gHBDbl-WhV7u39UwyFvt-3" value="&lt;div&gt;modbus.c (строка 191)&lt;/div&gt;&lt;div&gt;static int&amp;nbsp;&lt;font style=&quot;background-color: transparent; color: rgb(51, 153, 255); font-size: 18px;&quot;&gt;syscom_write&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;(RTS_HANDLE hCom, uint8_t* buf, size_t len) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; RTS_RESULT res;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; CAL_SysComPurge(hCom);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; RTS_UI32 ret = CAL_SysComWrite(hCom, buf, len, 0, &amp;amp;res);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; return res != ERR_OK &amp;amp;&amp;amp; ret != len ? -1 : 0;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" style="html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;" parent="1" vertex="1">
          <mxGeometry x="40" y="140" width="430" height="150" as="geometry" />
        </mxCell>
        <mxCell id="gHBDbl-WhV7u39UwyFvt-4" value="&lt;div&gt;modbus.c (строка 261)&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;static RTS_UI32 &lt;font style=&quot;font-size: 18px; color: rgb(51, 153, 255);&quot;&gt;mb_read&lt;/font&gt;(ModbusStateMachine* fsm)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp;{&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; RTS_UI32 size = CAL_SysComRead(fsm-&amp;gt;hCom, fsm-&amp;gt;rxBuf + fsm-&amp;gt;rxLen,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;MODBUS_MAX_LENGTH - fsm-&amp;gt;rxLen, 0, NULL);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if (size &amp;gt; 0) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; fsm-&amp;gt;rxLen += size;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; fsm-&amp;gt;timestamp = CAL_SysTimeGetMs();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; return size;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" style="html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;" parent="1" vertex="1">
          <mxGeometry x="40" y="340" width="430" height="180" as="geometry" />
        </mxCell>
        <mxCell id="qtXsbxlCK8YcV9-iouNY-1" value="&lt;div&gt;Общая архитектура&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. IoDrvKBus.c (верхний уровень)&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Вызывает функции из kbus.c для инициализации, открытия, опроса, закрытия KBus.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Реализует интерфейс Codesys для ввода-вывода.&lt;/div&gt;&lt;div&gt;2. kbus.c (логика KBus)&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Управляет состоянием шины и модулями.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Для обмена с модулями вызывает функции из kbus_comm.c (например, kbuscomm_start, kbuscomm_process).&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Для низкоуровневого обмена использует функции из modbus.c (например, отправка/приём пакетов).&lt;/div&gt;&lt;div&gt;3. kbus_comm.c (обмен с модулями)&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Реализует конечный автомат обмена с модулями KBus.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Для передачи и приёма данных вызывает функции из modbus.c.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Может вызывать обратные вызовы в kbus.c для обработки событий (например, ошибки, завершение обмена).&lt;/div&gt;&lt;div&gt;4. modbus.c (низкоуровневый протокол)&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Реализует отправку и приём пакетов Modbus через COM-порт.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Не знает о KBus, работает только с байтовыми потоками.&lt;/div&gt;&lt;div&gt;---&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1.&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Инициализация&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;IoDrvKBus.c вызывает kbus_init() из kbus.c.&lt;/div&gt;&lt;div&gt;2.&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Открытие&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;IoDrvKBus.c вызывает kbus_open() из kbus.c.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;kbus.c настраивает COM-порт, SMBus и т.д.&lt;/div&gt;&lt;div&gt;3.&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Опрос модулей&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;В цикле IoDrvKBus.c вызывает kbus_task() из kbus.c.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;kbus_task() вызывает kbuscomm_start() или kbuscomm_process() из kbus_comm.c.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;kbus_comm.c вызывает функции из modbus.c для отправки/приёма данных.&lt;/div&gt;&lt;div&gt;4.&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Закрытие&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;IoDrvKBus.c вызывает kbus_close() из kbus.c.&lt;/div&gt;&lt;div&gt;---&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;IoDrvKBus.c управляет всем процессом, вызывает функции из kbus.c.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;kbus.c — центральный диспетчер, делегирует обмен в kbus_comm.c и низкоуровневую работу в modbus.c.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;kbus_comm.c реализует автомат обмена, вызывает низкоуровневые функции из modbus.c.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;modbus.c работает только с байтами, не знает о KBus.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="-1785" y="-1600" width="770" height="520" as="geometry" />
        </mxCell>
        <mxCell id="FPRmQMnY9eR2uaSK9QJn-1" value="&lt;div&gt;Отправляет запросы на запись и чтение регистров&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;modbus.c (строка 262)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;void&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: rgb(51, 51, 255);&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;k&lt;/font&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;buscomm_process&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(&lt;/span&gt;&lt;div&gt;&lt;div&gt;KBusCommStateMachine *fsm)&amp;nbsp;&lt;/div&gt;&lt;/div&gt;" style="html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;" parent="1" vertex="1">
          <mxGeometry x="50" y="570" width="290" height="90" as="geometry" />
        </mxCell>
        <mxCell id="FPRmQMnY9eR2uaSK9QJn-2" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;RTS_UI32 CDECL SysComWrite(RTS_HANDLE hCom, unsigned char *pbyBuffer, RTS_UI32 uiSize, RTS_UI32 &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;ulTimeout, RTS_RESULT *pResult)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="-1080" y="1020" width="710" height="60" as="geometry" />
        </mxCell>
        <mxCell id="WCAfoDGU5FmjCLHIvdU8-1" value="&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b&gt;inp_mapped&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;static inline uint8_t inp_mapped(KBusModule* mod, KBusChannel chan) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; KBusChannelParameter* param = &amp;amp;mod-&amp;gt;parameter_values[chan];&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; return param-&amp;gt;base.mapped &amp;amp;&amp;amp; param-&amp;gt;configured;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Что делает функция inp_mapped&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Назначение:&lt;/div&gt;&lt;div&gt;Проверяет, &quot;отображён&quot; ли (т.е. используется ли) определённый канал ввода (например, дискретный, аналоговый и т.д.) в модуле mod.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Параметры:&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;mod — указатель на структуру модуля KBus (KBusModule*).&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;chan — номер канала (enum или индекс).&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Логика:&lt;/div&gt;&lt;div&gt;1.&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Получает структуру параметров канала:&lt;/div&gt;&lt;div&gt;KBusChannelParameter* param = &amp;amp;mod-&amp;gt;parameter_values[chan];&lt;/div&gt;&lt;div&gt;2.&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Проверяет два условия:&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;param-&amp;gt;base.mapped — канал &quot;отображён&quot; (т.е. назначен в проекте, не отключён).&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;param-&amp;gt;configured — канал сконфигурирован (настроен пользователем или системой).&lt;/div&gt;&lt;div&gt;3.&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Возвращает 1 (истина), если оба условия выполняются, иначе 0.&lt;/div&gt;&lt;div&gt;Для чего это нужно&lt;/div&gt;&lt;div&gt;Эта функция используется для фильтрации каналов, чтобы работать только с теми, которые реально используются и корректно настроены. Например, если канал не отображён или не сконфигурирован, его не будут опрашивать или управлять им.&lt;/div&gt;&lt;div&gt;Пример&lt;/div&gt;&lt;div&gt;Если у модуля есть 8 дискретных входов, но в проекте используются только 3, то только для этих трёх inp_mapped вернёт 1, для остальных — 0.&lt;/div&gt;&lt;div&gt;Возможные &quot;подводные камни&quot;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Если забыть сконфигурировать канал или не назначить его в проекте, функция всегда будет возвращать 0, и канал не будет участвовать в обмене.&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Функция не проверяет тип канала — только его статус в массиве параметров.&lt;/div&gt;&lt;div&gt;Если нужны детали по структурам или по использованию этой функции в других местах — уточните!&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" parent="1" vertex="1">
          <mxGeometry x="-2180" y="260" width="520" height="520" as="geometry" />
        </mxCell>
        <mxCell id="WCAfoDGU5FmjCLHIvdU8-2" value="&lt;div&gt;&lt;font style=&quot;color: rgb(102, 178, 255);&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 16px;&quot;&gt;&lt;font color=&quot;#66b2ff&quot;&gt;&lt;b&gt;KBusCommStateMachine&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;// Описывает состояние обмена с модулем&lt;/div&gt;&lt;div&gt;typedef struct {&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;ModbusStateMachine* &lt;b&gt;mb&lt;/b&gt;; // поля state ( WRITE, READ, PENDING, READY), txBuf (буфер передачи), rxBuf (буфер приема) и т.д.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;KBusCommState &lt;b&gt;state&lt;/b&gt;; // состояние kbuscomm_state_enter&amp;nbsp;(DINP, AINP, DOUT, AOUT и т.д.)&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;KBusModule* &lt;b&gt;mod&lt;/b&gt;; // указатель на структуру KBusModule, поля address (Modbus-адрес), discretes (число дискретных входов), analogs (число аналоговых входов) и т.д.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;uint8_t &lt;b&gt;err&lt;/b&gt;; // поле для хранения кода ошибки&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;uint8_t &lt;b&gt;err_cnt&lt;/b&gt;; // счётчик ошибок&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;uint8_t &lt;b&gt;idx&lt;/b&gt;; // индекс для циклов&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;uint16_t &lt;b&gt;regAddr&lt;/b&gt;; // адрес первого регистра для текущей операции&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;uint16_t &lt;b&gt;regAmount&lt;/b&gt;; // количество регистров для текущей операции&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;KBusAlarmsAmount &lt;b&gt;alarmsAmount&lt;/b&gt;; // количество аварий&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;KBusExtModAlarm &lt;b&gt;alarms&lt;/b&gt;[KBUS_ALARMS_AMOUNT]; // массив аварий&lt;/span&gt;&lt;/div&gt;&lt;div&gt;} KBusCommStateMachine;&amp;nbsp;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="-2980" y="-1450" width="420" height="330" as="geometry" />
        </mxCell>
        <mxCell id="WCAfoDGU5FmjCLHIvdU8-3" value="&lt;div&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;b&gt;mb_process&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;(ModbusStateMachine* fsm)&lt;/font&gt;&lt;/span&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Вызовы&amp;nbsp;&lt;/div&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" parent="1" vertex="1">
          <mxGeometry x="-2180" y="790" width="520" height="520" as="geometry" />
        </mxCell>
        <mxCell id="WCAfoDGU5FmjCLHIvdU8-4" value="&lt;div&gt;&lt;font style=&quot;color: rgb(102, 178, 255); font-size: 10px;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;&quot;&gt;ModbusStateMachine&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;typedef struct {&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; ModbusState state;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; RTS_HANDLE hCom;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; uint8_t txBuf[MODBUS_MAX_LENGTH];&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; uint8_t rxBuf[MODBUS_MAX_LENGTH];&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; int err;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; uint8_t err_cnt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; uint8_t attempts;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; uint16_t txLen;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; uint16_t rxLen;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; uint32_t timestamp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp; &amp;nbsp; uint32_t timeout;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;} &lt;b style=&quot;&quot;&gt;ModbusStateMachine&lt;/b&gt;;&lt;/font&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="-1860" y="1040" width="200" height="220" as="geometry" />
        </mxCell>
        <mxCell id="WCAfoDGU5FmjCLHIvdU8-5" value="&lt;div&gt;&lt;font color=&quot;#66b2ff&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;KBusAutoConfStateMachine&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;typedef struct {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; ModbusStateMachine* mb;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; KBusAutoConfState state;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; KBusModule* modules;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t err;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t err_cnt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t idx;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint32_t timestamp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; int smb;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t cnt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; bool init;&lt;/div&gt;&lt;div&gt;} &lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;KBusAutoConfStateMachine&lt;/font&gt;&lt;/b&gt;;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="-3450" y="-367.5" width="260" height="240" as="geometry" />
