        <mxCell id="Y8qQ0ax3hkKe-9IbpHJT-8" value="&lt;div&gt;&lt;font style=&quot;color: rgb(102, 178, 255);&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;ModbusStateMachine&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;typedef struct {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; ModbusState &lt;b&gt;state&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; RTS_HANDLE &lt;b&gt;hCom&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;txBuf&lt;/b&gt;[MODBUS_MAX_LENGTH];&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;rxBuf&lt;/b&gt;[MODBUS_MAX_LENGTH];&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; int &lt;b&gt;err&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;err_cnt&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint8_t &lt;b&gt;attempts&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint16_t &lt;b&gt;txLen&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint16_t &lt;b&gt;rxLen&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint32_t &lt;b&gt;timestamp&lt;/b&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; uint32_t &lt;b&gt;timeout&lt;/b&gt;;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;} &lt;b&gt;ModbusStateMachine&lt;/b&gt;;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="-2520" y="-1600" width="260" height="240" as="geometry" />
        </mxCell>
        <mxCell id="Y8qQ0ax3hkKe-9IbpHJT-9" value="&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;mb_read_input_registers() --&amp;gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b&gt;mb_start_write() --&amp;gt;&amp;nbsp;&lt;/b&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b&gt;mb_reset(), mb_request_build(),&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b&gt;mb_request_crc()&lt;/b&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;align=center;" parent="1" vertex="1">
