        <mxCell id="M-APucCFz-4uIC0XV3Aw-8" value="&lt;div&gt;static void kbuscomm_next_state_enter(KBusCommStateMachine *fsm) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if (fsm-&amp;gt;state != KBUSCOMM_STATE_FINISHED)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; kbuscomm_state_enter(fsm, fsm-&amp;gt;state + 1);&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;" style="whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="-790" y="110" width="350" height="80" as="geometry" />
        </mxCell>
        <mxCell id="Y8qQ0ax3hkKe-9IbpHJT-1" value="&lt;div&gt;&lt;b&gt;KBus* kBus&lt;/b&gt;&lt;br&gt;&lt;/div&gt;HookFunction() создает объект kBus, который указывает на структуру KBus:&amp;nbsp;KBus* kBus = &amp;amp;((IoDrvKBus*)s_pIBase)-&amp;gt;kBus; (строка 258)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-800" y="240" width="430" height="70" as="geometry" />
